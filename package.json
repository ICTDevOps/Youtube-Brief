{
  "name": "youtube-orchestrator",
  "version": "1.0.0",
  "description": "YouTube channel orchestrator for triggering N8N workflows with per-channel scheduling and web management UI.",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run copy-assets && tsc",
    "copy-assets": "cp node_modules/@tabler/core/dist/css/tabler.min.css public/ && cp node_modules/@tabler/core/dist/js/tabler.min.js public/",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --exec ts-node src/server.ts"
  },
  "keywords": [
    "youtube",
    "orchestrator",
    "n8n",
    "scheduler"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tabler/core": "^1.4.0",
    "bcryptjs": "^3.0.2",
    "cron-parser": "^5.4.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "fs-extra": "^11.3.2",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/helmet": "^0.0.48",
    "@types/node": "^24.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
